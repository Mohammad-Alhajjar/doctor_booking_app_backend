  "item": [
    {
      "name": "1. Login (Auto-save Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if(jsonData.token) {",
              "    pm.collectionVariables.set(\"auth_token\", jsonData.token);",
              "    console.log(\"Token has been saved automatically!\");",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"user@email.com\",\n    \"password\": \"user123456\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/login",
          "protocol": "http",
          "host": [
            "127",
            "0",
            "0",
            "1"
          ],
          "port": "8000",
          "path": [
            "login"
          ]
        }
      },
      "response": []
    },
